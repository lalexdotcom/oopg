{
	"name": "@lalex/oopg",
	"version": "1.0.0-rc.3",
	"description": "Type-safe, ergonomic PostgreSQL client for TypeScript",
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": ">=18"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"types": "./dist/index.d.ts",
	"readme": "README.md",
	"repository": {
		"type": "git",
		"url": "https://github.com/lalexdotcom/oopg.git"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rslib build",
		"check": "biome check --write",
		"dev": "rslib build --watch",
		"format": "biome format --write",
		"test": "rstest",
		"test:watch": "rstest --watch"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@lalex/console": "2.0.0-rc.1",
		"@rslib/core": "^0.20.0",
		"@rstest/adapter-rslib": "^0.2.1",
		"@rstest/core": "^0.9.0",
		"@types/node": "24",
		"@types/pg": "^8.20.0",
		"@types/pg-copy-streams": "^1.2.5",
		"@types/pg-cursor": "^2.7.2",
		"@types/through": "^0.0.33",
		"ts-toolbelt": "^9.6.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"eventemitter3": "^5.0.4",
		"pg": "^8.20.0",
		"pg-connection-string": "^2.12.0",
		"pg-copy-streams": "^7.0.0",
		"pg-cursor": "^2.19.0",
		"pg-query-stream": "^4.14.0",
		"through": "^2.3.8"
	},
	"packageManager": "pnpm@10.31.0"
}
